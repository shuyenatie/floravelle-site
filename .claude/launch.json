{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "floravelle",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),path=require('path');const root='D:/Codex-Workspace/Projects/floravelle-site';http.createServer((req,res)=>{let fp=path.join(root,req.url==='/'?'/index.html':req.url.split('?')[0]);const m={'html':'text/html','css':'text/css','js':'text/javascript'};fs.readFile(fp,(e,d)=>{if(e){res.writeHead(404);res.end('404')}else{res.writeHead(200,{'Content-Type':m[path.extname(fp)]||'text/plain'});res.end(d)}})}).listen(4173,'127.0.0.1',()=>console.log('ready on 4173'))"],
      "port": 4173
    }
  ]
}
